# ───────────── Bitrix24 ─────────────
B24_WEBHOOK_BASE=https://<portal>.bitrix24.ru/rest/1/<code>/
NODE_ENV=production
# Токен Bitrix MCP (JWT без префикса "Bearer "); используется в .mcp.json как ${B24_MCP_TOKEN}
B24_MCP_TOKEN=

# ───────────── Google Cloud ─────────────
# Путь к JSON ключу сервис-аккаунта. Если не задан — используются Application Default Credentials.
GOOGLE_APPLICATION_CREDENTIALS=/abs/path/to/gcp-sa-key.json
GOOGLE_CLOUD_PROJECT=my-gcp-project

# ───────────── Yandex Cloud ─────────────
# Достаточно ОДНОГО способа аутентификации (приоритет: OAuth > IAM > SA-ключ).
YC_OAUTH_TOKEN=
YC_IAM_TOKEN=
YC_SA_KEY_FILE=/abs/path/to/yc-sa-key.json
# Значения по умолчанию, чтобы не передавать их в каждый вызов:
YC_CLOUD_ID=
YC_FOLDER_ID=

# ───────────── Conspects / LLM ─────────────
# Основной провайдер для разбора расшифровок: OpenRouter.
OPENROUTER_API_KEY=
# Можно указать коротко gemini-2.5-flash — код нормализует в google/gemini-2.5-flash.
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_SITE_URL=https://leademy-dashboard.local
OPENROUTER_APP_NAME=Leademy Dashboard
